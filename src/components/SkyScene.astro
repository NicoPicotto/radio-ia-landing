<!-- Full-screen animated sky landscape -->
<div id="sky-scene" aria-hidden="true">

  <!-- Layer 1: Sky gradient (controlled by @property CSS vars) -->
  <div id="sky-bg"></div>

  <!-- Layer 2: Stars (canvas, fades in at night) -->
  <canvas id="stars-canvas"></canvas>

  <!-- Layer 3: Sun -->
  <div id="sun" class="celestial" role="img" aria-label="sol">
    <div class="sun-halo"></div>
    <div class="sun-core"></div>
  </div>

  <!-- Layer 4: Moon -->
  <div id="moon" class="celestial" role="img" aria-label="luna">
    <div class="moon-glow"></div>
    <div class="moon-core">
      <div class="crater crater-a"></div>
      <div class="crater crater-b"></div>
      <div class="crater crater-c"></div>
    </div>
  </div>

  <!-- Layer 5: Clouds (CSS-animated, visibility controlled by JS class) -->
  <div id="clouds-layer" class="clouds-0">
    <div class="cloud cloud-1">
      <svg viewBox="0 0 220 85" xmlns="http://www.w3.org/2000/svg">
        <path d="M25,72 Q8,72 8,55 Q8,35 28,32 Q32,12 58,18 Q66,2 90,10 Q110,2 128,18 Q150,12 158,35 Q178,33 178,55 Q178,72 158,72 Z" fill="white"/>
      </svg>
    </div>
    <div class="cloud cloud-2">
      <svg viewBox="0 0 170 68" xmlns="http://www.w3.org/2000/svg">
        <path d="M18,58 Q5,58 5,44 Q5,28 22,25 Q25,8 48,14 Q55,3 75,10 Q93,4 105,20 Q122,18 124,35 Q138,33 136,50 Q136,62 118,62 Z" fill="white"/>
      </svg>
    </div>
    <div class="cloud cloud-3">
      <svg viewBox="0 0 190 72" xmlns="http://www.w3.org/2000/svg">
        <path d="M20,62 Q6,62 6,48 Q6,30 24,28 Q28,10 52,16 Q60,4 82,12 Q102,5 118,22 Q138,20 140,40 Q155,38 153,56 Q153,68 133,68 Z" fill="white"/>
      </svg>
    </div>
    <div class="cloud cloud-4">
      <svg viewBox="0 0 145 58" xmlns="http://www.w3.org/2000/svg">
        <path d="M15,48 Q4,48 4,38 Q4,22 18,20 Q21,7 40,12 Q46,2 62,8 Q78,3 88,18 Q103,16 104,30 Q115,28 113,42 Q113,52 96,52 Z" fill="white"/>
      </svg>
    </div>
    <div class="cloud cloud-5">
      <svg viewBox="0 0 255 92" xmlns="http://www.w3.org/2000/svg">
        <path d="M28,78 Q10,78 10,60 Q10,40 32,37 Q36,14 66,20 Q74,4 100,12 Q122,3 145,20 Q168,14 178,38 Q200,35 202,58 Q202,76 178,78 Z" fill="white"/>
      </svg>
    </div>
  </div>

  <!-- Layer 6: Weather effects canvas (rain / snow) -->
  <canvas id="weather-canvas"></canvas>

  <!-- Layer 7: SVG hill silhouette (pampa argentina) -->
  <svg
    id="hills"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 1440 320"
    preserveAspectRatio="none"
  >
    <!-- Far hill (depth layer — ridge above back hill so it peeks into the sky) -->
    <path
      d="M0,230 C200,210 380,185 560,178 C740,172 920,180 1100,190 C1270,200 1390,212 1440,218 L1440,320 L0,320 Z"
      fill="var(--hill-back)"
      opacity="0.5"
    />
    <!-- Back hill -->
    <path
      d="M0,280 C120,248 240,210 380,225 C520,240 620,185 780,195 C940,205 1040,245 1180,218 C1320,190 1390,228 1440,235 L1440,320 L0,320 Z"
      fill="var(--hill-back)"
    />
    <!-- Tree silhouettes on back hill (eucaliptos pampeanos) -->
    <g fill="var(--hill-back)">
      <!-- left cluster — bases aligned to hill surface (y≈256 at x=88, y≈251 at x=108) -->
      <rect x="86" y="226" width="5" height="30" />
      <ellipse cx="88.5" cy="220" rx="14" ry="20" />
      <rect x="107" y="227" width="4" height="24" />
      <ellipse cx="109" cy="222" rx="11" ry="16" />
      <!-- center-right cluster — bases aligned to hill surface (y≈217-221 at x=960-995) -->
      <rect x="958" y="185" width="5" height="32" />
      <ellipse cx="960.5" cy="178" rx="14" ry="20" />
      <rect x="978" y="194" width="4" height="26" />
      <ellipse cx="980" cy="188" rx="10" ry="16" />
      <rect x="993" y="201" width="3.5" height="20" />
      <ellipse cx="994.5" cy="197" rx="8" ry="13" />
    </g>
    <!-- Front hill -->
    <path
      d="M0,310 C90,288 200,268 340,278 C480,288 570,252 700,258 C830,264 940,282 1080,264 C1220,246 1340,272 1440,265 L1440,320 L0,320 Z"
      fill="var(--hill-front)"
    />
    <!-- Grain silo silhouette (typical pampa landmark) -->
    <g fill="var(--hill-front)">
      <rect x="1300" y="248" width="12" height="28" />
      <ellipse cx="1306" cy="248" rx="6" ry="4" />
      <rect x="1318" y="254" width="10" height="22" />
      <ellipse cx="1323" cy="254" rx="5" ry="3.5" />
    </g>
  </svg>

  <!-- Layer 8: Fog overlay -->
  <div id="fog-layer"></div>

</div>

<style>
  #sky-scene {
    position: fixed;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }

  /* === SKY === */
  #sky-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      var(--sky-top) 0%,
      var(--sky-mid) 50%,
      var(--sky-bot) 100%
    );
    transition:
      --sky-top 90s ease,
      --sky-mid 90s ease,
      --sky-bot 90s ease;
  }

  /* === STARS === */
  #stars-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: var(--star-opacity, 1);
    transition: opacity 120s ease;
    pointer-events: none;
  }

  /* === SUN === */
  .celestial {
    position: absolute;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition:
      left 60s linear,
      top 60s linear,
      opacity 30s ease;
    pointer-events: none;
  }

  #sun {
    width: 70px;
    height: 70px;
  }

  .sun-halo {
    position: absolute;
    inset: -40px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 200, 60, 0.25) 0%, transparent 70%);
    animation: sun-pulse 4s ease-in-out infinite;
  }

  .sun-core {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 35%, #fff9d0, #ffd23f 45%, #ff9500);
    box-shadow:
      0 0 30px 10px rgba(255, 200, 60, 0.6),
      0 0 80px 30px rgba(255, 160, 20, 0.3);
  }

  @keyframes sun-pulse {
    0%, 100% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.05); opacity: 1; }
  }

  /* === MOON === */
  #moon {
    width: 52px;
    height: 52px;
  }

  .moon-glow {
    position: absolute;
    inset: -30px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(200, 220, 255, 0.15) 0%, transparent 70%);
  }

  .moon-core {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #e8eeff, #c8d8ff 60%, #a0b8ee);
    box-shadow:
      0 0 20px 6px rgba(160, 180, 255, 0.3),
      inset -8px -4px 16px rgba(80, 100, 180, 0.4);
    overflow: hidden;
  }

  .crater {
    position: absolute;
    border-radius: 50%;
    background: rgba(100, 120, 180, 0.25);
    border: 1px solid rgba(80, 100, 160, 0.2);
  }

  .crater-a { width: 12px; height: 12px; top: 22%; left: 28%; }
  .crater-b { width: 8px;  height: 8px;  top: 52%; left: 55%; }
  .crater-c { width: 6px;  height: 6px;  top: 36%; left: 60%; }

  /* === CLOUDS === */
  #clouds-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .cloud {
    position: absolute;
    transition: opacity 15s ease;
  }

  .cloud svg {
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.12));
    width: 100%;
    height: 100%;
  }

  /* Cloud positions and animations */
  .cloud-1 {
    width: 220px;
    top: 8%;
    animation: drift 85s linear infinite;
    animation-delay: -20s;
  }
  .cloud-2 {
    width: 165px;
    top: 22%;
    animation: drift 115s linear infinite;
    animation-delay: -55s;
  }
  .cloud-3 {
    width: 190px;
    top: 12%;
    animation: drift 70s linear infinite;
    animation-delay: -10s;
  }
  .cloud-4 {
    width: 140px;
    top: 32%;
    animation: drift 100s linear infinite;
    animation-delay: -72s;
  }
  .cloud-5 {
    width: 250px;
    top: 4%;
    animation: drift 130s linear infinite;
    animation-delay: -40s;
  }

  @keyframes drift {
    from { transform: translateX(110vw); }
    to   { transform: translateX(-30vw); }
  }

  /* Cloud visibility by level */
  #clouds-layer.clouds-0 .cloud { opacity: 0; }
  #clouds-layer.clouds-1 .cloud-1 { opacity: 0.7; }
  #clouds-layer.clouds-1 .cloud-2,
  #clouds-layer.clouds-1 .cloud-3,
  #clouds-layer.clouds-1 .cloud-4,
  #clouds-layer.clouds-1 .cloud-5 { opacity: 0; }
  #clouds-layer.clouds-2 .cloud-1,
  #clouds-layer.clouds-2 .cloud-2,
  #clouds-layer.clouds-2 .cloud-3 { opacity: 0.75; }
  #clouds-layer.clouds-2 .cloud-4,
  #clouds-layer.clouds-2 .cloud-5 { opacity: 0; }
  #clouds-layer.clouds-3 .cloud { opacity: 0.9; }

  /* Overcast darkens clouds slightly */
  #clouds-layer.clouds-3 .cloud svg path { fill: #d8d8d8; }

  /* === WEATHER CANVAS === */
  #weather-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0;
    transition: opacity 5s ease;
  }

  #weather-canvas.active {
    opacity: 1;
  }

  /* === HILLS === */
  #hills {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    /* width always covers 100vw; on narrow/tall viewports it's wider (crops sides).
       height auto-derives from the SVG intrinsic 1440:320 ratio — no deformation. */
    width: max(100vw, calc(40vh * 4.5));
    height: auto;
    transition:
      --hill-back 90s ease,
      --hill-front 90s ease;
  }

  /* === FOG === */
  #fog-layer {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 35%;
    background: linear-gradient(to top, rgba(200, 210, 220, 0.55), transparent);
    opacity: 0;
    transition: opacity 8s ease;
    pointer-events: none;
  }

  #fog-layer.active {
    opacity: 1;
  }
</style>
