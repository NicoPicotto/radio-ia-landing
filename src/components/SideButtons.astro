<!-- Subtle side action buttons, vertically centered -->

<!-- Left: Donate -->
<button
  id="btn-donate"
  class="side-btn left"
  aria-label="Apoyar el proyecto"
  onclick="window.open('https://link.mercadopago.com.ar/radioai', '_blank', 'noopener,noreferrer')"
  data-reveal="left"
>
  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path
      d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
      fill="currentColor"
    />
  </svg>
  <span class="btn-tooltip">Apoyar el proyecto</span>
</button>

<!-- Right: About the project -->
<button
  id="btn-about"
  class="side-btn right"
  aria-label="Sobre el proyecto"
  title="Sobre el proyecto"
  data-reveal="right"
>
  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/>
    <path d="M12 8v1" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    <path d="M12 11v5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
  </svg>
</button>

<style>
  .side-btn {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;

    width: 44px;
    height: 44px;
    border-radius: 50%;

    display: flex;
    align-items: center;
    justify-content: center;

    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.45);
    cursor: pointer;

    transition:
      background 0.3s ease,
      color 0.3s ease,
      transform 0.3s ease,
      opacity 0.3s ease,
      box-shadow 0.3s ease;
  }

  .btn-tooltip {
    position: absolute;
    left: calc(100% + 12px);
    top: 50%;
    transform: translateY(-50%);
    white-space: nowrap;
    background: rgba(8, 12, 28, 0.88);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    padding: 5px 10px;
    border-radius: 8px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .side-btn:hover .btn-tooltip {
    opacity: 1;
  }

  .side-btn:hover {
    background: rgba(255, 255, 255, 0.14);
    color: rgba(255, 255, 255, 0.85);
    transform: translateY(-50%) scale(1.1);
    box-shadow: 0 0 16px rgba(255, 255, 255, 0.1);
  }

  .side-btn svg {
    width: 18px;
    height: 18px;
  }

  .side-btn.left {
    left: 28px;
  }

  .side-btn.right {
    right: 28px;
  }

  /* On small screens, move them slightly inward */
  @media (max-width: 480px) {
    .side-btn.left  { left: 14px; }
    .side-btn.right { right: 14px; }
  }
</style>
