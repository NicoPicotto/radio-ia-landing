<!-- Subtle side action buttons, vertically centered -->

<!-- Left: Radio info -->
<button
  id="btn-radio"
  class="side-btn left"
  aria-label="Sobre la radio"
  data-reveal="left"
>
  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M5 12.5a7 7 0 0 1 14 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    <path d="M8.5 12.5a3.5 3.5 0 0 1 7 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    <circle cx="12" cy="15" r="1.2" fill="currentColor"/>
  </svg>
  <span class="btn-tooltip">La Radio</span>
</button>

<!-- Right: Creator / project -->
<button
  id="btn-creator"
  class="side-btn right"
  aria-label="Sobre el proyecto"
  data-reveal="right"
>
  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.7"/>
    <path d="M4 20c0-4 3.582-7 8-7s8 3 8 7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
  </svg>
  <span class="btn-tooltip tooltip-left">El Proyecto</span>
</button>

<style>
  .side-btn {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;

    width: 44px;
    height: 44px;
    border-radius: 50%;

    display: flex;
    align-items: center;
    justify-content: center;

    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.45);
    cursor: pointer;

    transition:
      background 0.3s ease,
      color 0.3s ease,
      transform 0.3s ease,
      opacity 0.3s ease,
      box-shadow 0.3s ease;
  }

  .btn-tooltip {
    position: absolute;
    left: calc(100% + 12px);
    top: 50%;
    transform: translateY(-50%);
    white-space: nowrap;
    background: rgba(8, 12, 28, 0.88);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    padding: 5px 10px;
    border-radius: 8px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .btn-tooltip.tooltip-left {
    left: auto;
    right: calc(100% + 12px);
  }

  .side-btn:hover .btn-tooltip {
    opacity: 1;
  }

  .side-btn:hover {
    background: rgba(255, 255, 255, 0.14);
    color: rgba(255, 255, 255, 0.85);
    transform: translateY(-50%) scale(1.1);
    box-shadow: 0 0 16px rgba(255, 255, 255, 0.1);
  }

  .side-btn svg {
    width: 18px;
    height: 18px;
  }

  .side-btn.left {
    left: 28px;
  }

  .side-btn.right {
    right: 28px;
  }

  @media (max-width: 480px) {
    .side-btn.left  { left: 14px; }
    .side-btn.right { right: 14px; }
  }
</style>
